# Backend environment variables.
# Copy this file to .env and edit values as needed.

# Optional Hugging Face auth token to avoid rate limits during model download.
HF_TOKEN=

# Optional Hugging Face cache locations.
HF_HOME=$HOME/.cache/huggingface
HF_HUB_CACHE=$HOME/.cache/huggingface/hub
HUGGINGFACE_HUB_CACHE=$HOME/.cache/huggingface/hub

# Optional Bent microservice URL (leave empty for fallback behavior).
# Examples:
# - local microservice: http://127.0.0.1:8010
# - compose service: http://bent-runtime:8010
BENT_SERVICE_URL=

# Optional Bent request timeout (seconds).
BENT_SERVICE_TIMEOUT_SECONDS=60

# =========================================
# SSL + public gateway configuration
# =========================================
# Primary public domain for HTTPS termination.
SSL_DOMAIN=l2g.aiteb.app
# Optional aliases for the same certificate and routing (space or comma separated).
SSL_DOMAIN_ALIASES=www.l2g.aiteb.app
# Email for Let's Encrypt account.
SSL_EMAIL=ops@l2g.aiteb.app
# Let's Encrypt webroot for HTTP-01 challenge.
SSL_CERTBOT_WEBROOT=/var/www/certbot
# Set webroot (default) or standalone. Use standalone only if port 80 can be temporarily released.
CERTBOT_MODE=webroot
